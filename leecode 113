/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
    public:
      vector<vector<int>> ans; //用來存所有符合條件的路徑
      vector<int> path; //紀錄走到的路

      void dfs(TreeNode* node, int targetSum) //遞迴函式，目前走到 node
      {
        if (node == nullptr) return;  //走到空的地方，就停下
        path.push_back(node->val);
        if (node->left == nullptr && node->right == nullptr) {
    if (targetSum == node->val) //總額等於node丟入val的數值，回傳ans/path
     {
        ans.push_back(path);
     }
        }
      
        dfs(node->left, targetSum - node->val);
        dfs(node->right, targetSum - node->val);
        path.pop_back();//當這個節點探索完之後，要把它從 path 移掉，這樣回到上一層時，path 才會恢復原狀。
       }
    vector<vector<int>> pathSum(TreeNode* root, int targetSum) {
        dfs(root, targetSum);
        return ans;
    }
};
